[global]
    monitor = 0
    follow = mouse

    width = 340
    height = 300

    origin = top-right
    offset = 10x10

    scale = 0

    notification_limit = 8

    progress_bar = true
    progress_bar_height = 6
    progress_bar_frame_width = 0

    transparency = 0

    corner_radius = 18

    padding = 16
    horizontal_padding = 16
    text_icon_padding = 12

    gap_size = 10

    separator_height = 0

    frame_width = 1
    frame_color = "#ffffff12"

    font = JetBrainsMono Nerd Font 11

    line_height = 6

    markup = full
    format = "<b>%s</b>\n%b"

    alignment = left
    vertical_alignment = center

    icon_corner_radius = 12
    icon_position = left
    min_icon_size = 42
    max_icon_size = 56

    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    background = "#101217ee"
    foreground = "#f5f7fa"
    timeout = 4

[urgency_normal]
    background = "#12141af2"
    foreground = "#f5f7fa"
    frame_color = "#ffffff10"
    timeout = 6

[urgency_critical]
    background = "#1b1b22ee"
    foreground = "#ffb4b4"
    frame_color = "#ff808044"
    timeout = 0